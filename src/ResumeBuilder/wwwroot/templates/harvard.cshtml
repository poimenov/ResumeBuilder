@using static ResumeBuilder.Services
@model Resume
<!DOCTYPE html>
<html>

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Name - @Model.Headline</title>
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,600,700" rel="stylesheet">

    <style type="text/css">
            * {
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
                box-sizing: border-box;
            }

            html {
                height: 100%;
            }

            body {
                font-family: 'Source Sans Pro', 'Helvetica', Arial, sans-serif;
                background: #f3f4f6;
                min-height: 100vh;
                padding: 20px;
                margin: 0;
                font-size: 12px;
                line-height: 18px;
                color: #333333;
            }

            .mx-auto {
                max-width: 21cm;
                margin: 0 auto;
                width: 100%;
            }

            .resume-preview-container {
                background: white;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
                border-radius: 12px;
                overflow: hidden;
                width: 100%;
                position: relative;
                min-height: auto;
            }

            h1 {
                letter-spacing: 0.08em;
                text-transform: uppercase;
                font-style: normal;
                font-size: 30px;
                margin: 0;
                padding: 10px 0 10px 0;
                font-weight: 600;
            }

            h2 {
                text-transform: uppercase;
                font-size: 17px;
                font-weight: 600;
                margin: 0;
                padding: 0;
            }

            h3 {
                font-size: 14px;
                font-weight: 600;
                margin: 5px 0 0 0;
                padding: 0;
            }

            p {
                color: #4c4c4c;
                line-height: 18px;
                font-weight: 400;
                margin: 0;
                padding: 0;
            }

            .sections {
                margin-left: 235px;
                padding: 10px 10px 10px 10px;
            }

            .section {
                position: relative;
                width: 100%;
                padding: 0;
                margin-bottom: 10px;
            }

            .section a {
                color: #4c4c4c;
                text-decoration: none;
            }

            li[data-list="bullet"] {
                list-style-type: disc;
            }

            .section.section--summary {
                margin-bottom: 10px;
            }

            .section--title {
                display: inline-block;
                position: relative;
                width: 100%;
                z-index: 99;
                margin: 0;
                font-weight: 600;
                background: #fff;
                padding: 10px 0 10px 10px;
                border-top: 1px solid #d2d2d2;
                page-break-inside: avoid;
            }

            .section--title-icon {
                position: relative;
                top: 0px;
                display: inline-block;
                height: 32px;
                width: 32px;
                margin-left: -15px;
                margin-right: 10px;
                border-radius: 50%;
                border: 1px solid #3f6592;
            }

            .section--title-icon svg {
                position: relative;
                top: 4px;
                left: 5px;
                height: 20px;
                width: 20px;
                fill: #3f6592;
            }

            .timeline-wrapper {
                position: relative;
                padding-left: 30px;
            }

            .timeline-line {
                position: absolute;
                left: 15px;
                top: 8px;
                bottom: 8px;
                width: 2px;
                background: #3f6592;
            }

            .timeline-item {
                position: relative;
                margin-bottom: 25px;
                padding-bottom: 10px;
            }

            .timeline-item:last-child {
                margin-bottom: 0;
            }

            .timeline-dot {
                position: absolute;
                left: -20px;
                top: 2px;
                width: 12px;
                height: 12px;
                border-radius: 50%;
                background: white;
                border: 2px solid #3f6592;
                z-index: 2;
            }

            .experience-date {
                font-size: 12px;
                color: #3f6592;
                font-weight: 600;
                margin-bottom: 5px;
            }

            .experience-company {
                font-size: 14px;
                font-weight: 700;
                color: #333;
                margin-bottom: 3px;
            }

            .experience-company a {
                color: #333;
                text-decoration: none;
            }

            .experience-company a:hover {
                text-decoration: underline;
                color: #3f6592;
            }

            .experience-position {
                font-size: 13px;
                font-weight: 500;
                color: #666;
                margin-bottom: 8px;
                font-style: italic;
            }

            .experience-description {
                font-size: 12px;
                color: #4c4c4c;
                line-height: 18px;
            }

            .experience-description ul,
            .experience-description ol {
                margin: 0;
                padding-left: 20px;
            }

            .experience-description ul li,
            .experience-description ol li {
                margin-bottom: 4px;
            }

            .experience-description ul li:last-child,
            .experience-description ol li:last-child {
                margin-bottom: 0;
            }

            .education-date {
                font-size: 12px;
                color: #3f6592;
                font-weight: 600;
                margin-bottom: 5px;
            }

            .education-school {
                font-size: 14px;
                font-weight: 700;
                color: #333;
                margin-bottom: 3px;
            }

            .education-degree {
                font-size: 13px;
                font-weight: 500;
                color: #666;
                margin-bottom: 5px;
            }

            .education-area {
                font-size: 12px;
                color: #4c4c4c;
            }

            .certification-list {
                margin: 0;
                padding-left: 20px;
            }

            .certification-list li {
                margin-bottom: 5px;
            }

            .sidebar {
                position: absolute;
                top: 0;
                left: 0;
                color: #fff;
                padding: 10px 0 10px 14px;
                width: 235px;
                min-height: 100%;
                height: 100%;
                background: #3f6592;
            }

            .avatar {
                position: relative;
                display: inline-block;
                z-index: 2;
                padding: 0;
                margin: 0 0 10px 9px;
                height: 155px;
                width: 155px;
                border-radius: 50%;
                background-size: cover !important;
                border: 2px solid #fff;
            }

            .sidebar--data {
                display: block;
            }

            .sidebar--title {
                display: inline-block;
                font-size: 15px;
                font-style: normal;
                position: relative;
                width: 88%;
                padding: 10px 0 5px 0;
                margin: 0;
                page-break-inside: avoid;
                letter-spacing: 0.08em;
            }

            .sidebar--title span {
                display: inline-block;
                width: 100%;
                margin: 0;
                padding: 0;
                font-weight: 600;
                font-style: normal;
                padding-right: 2px;
                z-index: 1;
                background: #3f6592;
            }

            .sidebar--label {
                font-weight: 600;
            }

            .sidebar--list {
                display: block;
                list-style: none;
                margin: 0;
                padding: 0;
            }

            .sidebar--item {
                display: block;
                list-style: none;
                position: relative;
                font-size: 12px;
                margin: 0;
                padding: 0 5px 8px 0;
            }

            .contact-item {
                position: relative;
                padding-left: 23px;
                margin-bottom: 10px;
                font-size: 11px;
                line-height: 1.4;
            }

            .contact-item svg {
                position: absolute;
                top: 2px;
                left: 0;
                width: 15px;
                height: 15px;
                fill: #fff;
            }

            .contact-item a,
            .contact-item span {
                color: #fff;
                text-decoration: none;
                word-break: break-all;
            }

            .contact-item a:hover {
                text-decoration: underline;
            }

            .skills-keywords {
                padding: 2px 0 6px 0;
                font-size: 11px;
                opacity: 0.85;
                line-height: 1.4;
            }

            .language-stars {
                display: inline-block;
                position: relative;
                top: 2px;
                float: right;
                margin-right: 10px;
            }

            .language-stars svg {
                fill: rgba(255, 255, 255, 0.4);
                width: 12px;
                height: 12px;
                margin-left: 2px;
            }

            .language-stars svg.active {
                fill: #fff;
            }

            .sidebar--item.language-item {
                overflow: hidden;
                padding: 6px 5px 8px 0;
            }

            @@media print {
                body {
                    background: white;
                    padding: 0;
                    margin: 0;
                }

                .resume-preview-container {
                    box-shadow: none;
                    border-radius: 0;
                }
            }
    </style>
</head>

<body>
    <div class="mx-auto">
        <div class="resume-preview-container" style="position: relative; min-height: 500px;">
            <aside class="sidebar">
                <div class="avatar"
                     style="background:url('@Model.Picture') no-repeat center; background-size: cover;background-color: white;">
                    &nbsp;</div>

                    <div class="sidebar--data">
                        <h2 class="sidebar--title">
                            <span>Personal</span>
                        </h2>

                        <div class="contact-item">
                            <svg fill="#ffffff" height="24" viewBox="0 0 24 24" width="24"
                                 xmlns="http://www.w3.org/2000/svg">
                                <path
                                d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                                <path d="M0 0h24v24H0z" fill="none" />
                            </svg>
                            <span>@Model.Name</span>
                        </div>

                        <div class="contact-item">
                            <svg fill="#ffffff" height="24" viewBox="0 0 24 24" width="24"
                                 xmlns="http://www.w3.org/2000/svg">
                                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
                                <path d="M0 0h24v24H0z" fill="none" />
                            </svg>
                            <span>@Model.Location</span>
                        </div>

                        <div class="contact-item">
                            <svg fill="#ffffff" height="24" viewBox="0 0 24 24" width="24"
                                 xmlns="http://www.w3.org/2000/svg">
                                <path d="M0 0h24v24H0z" fill="none" />
                                <path
                                d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z" />
                            </svg>
                            <span dir="ltr">@Model.Phone</span>
                        </div>

                        <div class="contact-item">
                            <svg fill="#ffffff" height="24" viewBox="0 0 24 24" width="24"
                                 xmlns="http://www.w3.org/2000/svg">
                                <path
                                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
                                <path d="M0 0h24v24H0z" fill="none" />
                            </svg>
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        </div>

                        @foreach (var link in Model.Links)
                        {
                            <div class="contact-item">
                                <svg fill="#ffffff" height="24" viewBox="0 0 24 24" width="24"
                                     xmlns="http://www.w3.org/2000/svg">
                                    <path d="M0 0h24v24H0z" fill="none" />
                                    <path
                                    d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z" />
                                </svg>
                                <a href="@link" target="_blank" rel="noopener">
                                    @{
                                        if (Uri.TryCreate(link, UriKind.Absolute, out var uri))
                                        {
                                            if (uri.Host.Contains("github"))
                                            {
                                                @:GitHub
                                            }
                                            else if (uri.Host.Contains("linkedin"))
                                            {

                                                @:LinkedIn
                                            }
                                            else
                                            {

                                                @:Website
                                            }
                                        }
                                        else
                                        {

                                            @:Website
                                        }
                                    }
                                </a>
                            </div>
                        }
                    </div>

                    <div class="sidebar--data">
                        <h2 class="sidebar--title">
                            <span>Skills</span>
                        </h2>
                        <ul class="sidebar--list">
                            @foreach (var skill in Model.Skills)
                            {
                                <li class="sidebar--item">
                                    <span class="sidebar--label">@skill.Name</span>
                                </li>
                                if (skill.Keywords.Any())
                                {
                                    <div class="skills-keywords">
                                        @string.Join(", ", skill.Keywords)
                                    </div>
                                }
                            }
                        </ul>
                    </div>

                    <div class="sidebar--data">
                        <h2 class="sidebar--title">
                            <span>Languages</span>
                        </h2>
                        <ul class="sidebar--list">
                            @foreach (var language in Model.Languages)
                            {
                                <li class="sidebar--item language-item">
                                    <span class="sidebar--label">@language.Name
                                        @if (!string.IsNullOrEmpty(language.Fluency))
                                        {
                                            <text>(@language.Fluency)</text>
                                        }
                                    </span>
                                    <span class="language-stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= language.Level)
                                            {
                                                <svg class="active" fill="#ffffff" height="12" viewBox="0 0 24 24" width="12"
                                                     xmlns="http://www.w3.org/2000/svg">
                                                    <path
                                                    d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                                                </svg>
                                            }
                                            else
                                            {
                                                <svg fill="#ffffff" height="12" viewBox="0 0 24 24" width="12"
                                                     xmlns="http://www.w3.org/2000/svg" style="opacity: 0.4;">
                                                    <path
                                                    d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                                                </svg>
                                            }
                                        }
                                    </span>
                                </li>
                            }
                        </ul>
                    </div>
                </aside>

                <div class="sections">
                    <div class="section--name">
                        <h1>@Model.Name</h1>
                        <h2>@Model.Headline</h2>
                    </div>

                    <div class="section section--summary">
                        <div class="section--content" style="padding: 0;">
                            <p>@Raw(Model.Summary)</p>
                        </div>
                    </div>

                    <div class="section">
                        <div class="section--title">
                            <h2>
                                <i class="section--title-icon work">
                                    <svg fill="#000000" height="24" viewBox="0 0 24 24" width="24"
                                         xmlns="http://www.w3.org/2000/svg">
                                        <path
                                        d="M10 16v-1H3.01L3 19c0 1.11.89 2 2 2h14c1.11 0 2-.89 2-2v-4h-7v1h-4zm10-9h-4.01V5l-2-2h-4l-2 2v2H4c-1.1 0-2 .9-2 2v3c0 1.11.89 2 2 2h6v-2h4v2h6c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zm-6 0h-4V5h4v2z" />
                                    </svg>
                                </i>
                                Work experience
                            </h2>
                        </div>
                        <div class="timeline-wrapper">
                            <div class="timeline-line"></div>
                            @foreach (var experience in Model.Experiences)
                            {
                                <div class="timeline-item">
                                    <div class="timeline-dot"></div>
                                    <div class="experience-date">@experience.Period</div>
                                    <div class="experience-company">
                                        @if (experience.Website != null)
                                        {
                                            <a href="@experience.Website.AbsoluteUri" target="_blank"
                                               rel="noopener">@experience.Company</a>
                                        }
                                        else
                                        {
                                            @experience.Company
                                        }
                                    </div>
                                    <div class="experience-position">@experience.Position</div>
                                    @if (!string.IsNullOrEmpty(experience.Description))
                                    {
                                        <div class="experience-description">
                                            @Raw(experience.Description)
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="section">
                        <div class="section--title">
                            <h2>
                                <i class="section--title-icon education">
                                    <svg height="24" viewBox="0 0 24 24" width="24" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M0 0h24v24H0z" fill="none" />
                                        <path
                                        d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z" />
                                    </svg>
                                </i>
                                Education and Qualifications
                            </h2>
                        </div>
                        <div class="timeline-wrapper">
                            <div class="timeline-line"></div>
                            @foreach (var education in Model.Educations)
                            {
                                <div class="timeline-item">
                                    <div class="timeline-dot"></div>
                                    <div class="education-date">@education.Period</div>
                                    <div class="education-school">
                                        @if (education.Website != null)
                                        {
                                            <a href="@education.Website.AbsoluteUri" target="_blank" rel="noopener"
                                               style="color: #333; text-decoration: none;">@education.School</a>
                                        }
                                        else
                                        {
                                            @education.School
                                        }
                                        @if (!string.IsNullOrEmpty(education.Location))
                                        {
                                            <text>, @education.Location</text>
                                        }
                                    </div>
                                    <div class="education-degree">@education.Degree</div>
                                    @if (!string.IsNullOrEmpty(education.Area))
                                    {
                                        <div class="education-area">@education.Area</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    <div class="section">
                        <div class="section--title">
                            <h2>
                                <i class="section--title-icon single-textarea">
                                    <svg fill="#000000" height="24" viewBox="0 0 24 24" width="24"
                                         xmlns="http://www.w3.org/2000/svg">
                                        <path d="M14 17H4v2h10v-2zm6-8H4v2h16V9zM4 15h16v-2H4v2zM4 5v2h16V5H4z" />
                                        <path d="M0 0h24v24H0z" fill="none" />
                                    </svg>
                                </i>
                                Certification
                            </h2>
                        </div>
                        <div class="section--content section--content-single-textarea">
                            <ul class="certification-list">
                                @foreach (var cert in Model.Certifications)
                                {
                                    <li>
                                        <strong>@cert.Title</strong>
                                        @if (!string.IsNullOrEmpty(cert.Issuer))
                                        {
                                            <text> - @cert.Issuer</text>
                                        }
                                        @if (!string.IsNullOrEmpty(cert.Date))
                                        {
                                            <text> (@cert.Date)</text>
                                        }
                                        @if (cert.Website != null)
                                        {
                                            <text> - <a href="@cert.Website.AbsoluteUri" target="_blank"
                                                            rel="noopener">@cert.Label</a></text>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </body>

    </html>