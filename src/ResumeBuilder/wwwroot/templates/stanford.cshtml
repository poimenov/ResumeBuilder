@using static ResumeBuilder.Services
@model Resume
<!DOCTYPE html>
<html>

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Name - @Model.Headline</title>
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:400,600,700" rel="stylesheet">
    <style type="text/css">
            * {
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
                box-sizing: border-box;
            }

            html {
                height: 100%;
            }

            body {
                font-family: 'Source Sans Pro', 'Helvetica', Arial, sans-serif;
                background: #f3f4f6;
                min-height: 100vh;
                padding: 20px;
                margin: 0;
                font-size: 12px;
                line-height: 22px;
                color: #333333;
            }

            .mx-auto {
                max-width: 21cm;
                margin: 0 auto;
                width: 100%;
            }

            .resume-preview-container {
                background: white;
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
                border-radius: 12px;
                overflow: hidden;
                width: 100%;
                position: relative;
                min-height: auto;
            }

            h1 {
                font-style: normal;
                font-size: 30px;
                margin: 0 0 10px 0;
                padding: 0 0 10px 0;
                font-weight: 600;
            }

            h2 {
                font-size: 17px;
                font-weight: 600;
                margin: 0;
                padding: 0;
            }

            h3 {
                font-size: 14px;
                font-weight: 600;
                margin: 0;
                padding: 0;
                max-width: 430px;
            }

            p {
                color: #4c4c4c;
                line-height: 18px;
                font-weight: 400;
                margin: 0;
                padding: 0;
                text-align: left;
            }

            hr {
                border: none;
                height: 1px;
                width: 100%;
                padding: 0;
                margin: 0;
                background: #d2d2d2;
            }

            .section--name {
                display: block;
                border-bottom: 1px solid #d2d2d2;
            }

            .sections {
                margin-left: 235px;
                padding: 10px 10px 10px 10px;
            }

            .section {
                position: relative;
                width: 100%;
                padding: 0;
                margin-bottom: 10px;
            }

            .section:last-child {
                margin-bottom: 0;
            }

            .section p {
                display: block;
                font-style: normal;
            }

            .section a {
                color: #333;
                text-decoration: none;
            }

            .section--title {
                display: block;
                position: relative;
                z-index: 99;
                margin: 0 0 0 0;
                font-weight: 600;
                background: #fff;
                padding: 10px 0 10px 0;
                page-break-inside: avoid;
                border-bottom: 1px solid #d2d2d2;
            }

            .section--heading-group {
                display: block;
                padding: 10px 0 0 0;
                margin: 0;
            }

            .section--list {
                display: block;
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .section--item {
                display: block;
                position: relative;
                list-style: none;
                padding: 0;
                margin: 0;
            }

            .section--date {
                position: absolute;
                right: 0;
                text-align: right;
                top: 10px;
                width: 142px;
                font-size: 12px;
                padding: 0;
                margin: 0;
            }

            .section--heading {
                display: block;
                padding: 0;
                margin: 0;
            }

            .section--sub-heading {
                display: block;
                padding: 3px 0 0 0;
                margin: 0;
                font-style: italic;
                font-size: 12px;
            }

            .section--content {
                display: block;
                padding: 5px 0 0 0;
                margin: 0;
            }

            .section--content ul,
            .section--content ol {
                white-space: normal;
                font-weight: 400;
                list-style-position: outside;
                color: #4c4c4c;
                margin: 0;
                padding: 0 0 0 16px;
                text-align: left;
            }

            .section--content ul li,
            .section--content ol li {
                line-height: 18px;
                margin-bottom: 4px;
            }

            .section--content ul li:last-child,
            .section--content ol li:last-child {
                margin-bottom: 0;
            }

            .section--content ul li {
                list-style-type: disc;
            }

            li[data-list="bullet"] {
                list-style-type: disc;
            }

            .section--content ol {
                padding-left: 14px;
            }

            .section--content-single-textarea {
                padding-top: 5px;
            }

            .sidebar {
                position: absolute;
                top: 0;
                left: 0;
                color: #fff;
                padding: 10px 0 10px 10px;
                width: 235px;
                min-height: 100%;
                height: 100%;
                background: #434a54;
            }

            .sidebar.sidebar--no-avatar {
                padding-top: 10px;
            }

            .avatar {
                display: inline-block;
                padding: 0;
                margin: 0 0 0 9px;
                height: 155px;
                width: 155px;
                border-radius: 50%;
                background-size: cover !important;
                background-position: center !important;
            }

            .sidebar--data {
                display: block;
            }

            .sidebar--title {
                font-size: 15px;
                font-style: normal;
                padding: 10px 0 8px 0;
                margin: 0 0 5px 0;
                page-break-inside: avoid;
                border-bottom: 1px solid #fff;
            }

            .contact-item {
                display: flex;
                align-items: flex-start;
                gap: 8px;
                margin-bottom: 8px;
                font-size: 11px;
                line-height: 1.4;
            }

            .contact-item svg {
                width: 14px;
                height: 14px;
                fill: #fff;
                flex-shrink: 0;
                margin-top: 2px;
            }

            .contact-item a,
            .contact-item span {
                color: #fff;
                text-decoration: none;
                word-break: break-all;
            }

            .contact-item a:hover {
                text-decoration: underline;
            }

            .sidebar--label {
                font-weight: 600;
                display: inline-block;
            }

            .sidebar--list {
                display: block;
                list-style: none;
                margin: 0;
                padding: 0;
            }

            .sidebar--item {
                display: block;
                list-style: none;
                font-size: 12px;
                margin: 0;
                page-break-inside: avoid;
                padding: 6px 5px 0 0;
            }

            .sidebar--item.skill-item {
                padding: 6px 0 0 0;
            }

            .sidebar--item.skill-item .sidebar--label {
                font-weight: 600;
                font-size: 12px;
            }

            .skills-keywords {
                padding: 2px 0 6px 0;
                font-size: 11px;
                opacity: 0.85;
                line-height: 1.4;
            }

            .language-item {
                margin-bottom: 10px;
            }

            .language-name {
                font-weight: 600;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .language-level-dots {
                display: flex;
                gap: 6px;
                margin-top: 4px;
            }

            .level-dot {
                width: 10px;
                height: 10px;
                border: 1px solid rgba(255, 255, 255, 0.5);
                border-radius: 50%;
                background: transparent;
            }

            .level-dot.active {
                background: #fff;
                border-color: #fff;
            }

            @@media print {
                body {
                    background: white;
                    padding: 0;
                    margin: 0;
                }

                .resume-preview-container {
                    box-shadow: none;
                    border-radius: 0;
                }
            }
    </style>
</head>

<body>
    <div class="mx-auto">
        <div class="resume-preview-container" style="position: relative; min-height: 500px;">
            <aside class="sidebar">
                <div class="avatar"
                     style="background:url('@Model.Picture') no-repeat center; background-size: cover;background-color: white;">
                    &nbsp;</div>

                    <div class="sidebar--data">
                        <h2 class="sidebar--title" style="margin-bottom: 4px;">Personal</h2>
                        <div class="contact-item">
                            <svg fill="#fff" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                                <path
                                d="M128,64a40,40,0,1,0,40,40A40,40,0,0,0,128,64Zm0,64a24,24,0,1,1,24-24A24,24,0,0,1,128,128Zm0-112a88.1,88.1,0,0,0-88,88c0,31.4,14.51,64.68,42,96.25a254.19,254.19,0,0,0,41.45,38.3,8,8,0,0,0,9.18,0A254.19,254.19,0,0,0,174,200.25c27.45-31.57,42-64.85,42-96.25A88.1,88.1,0,0,0,128,16Zm0,206c-16.53-13-72-60.75-72-118a72,72,0,0,1,144,0C200,161.23,144.53,209,128,222Z" />
                            </svg>
                            <span>@Model.Location</span>
                        </div>

                        <div class="contact-item">
                            <svg fill="#fff" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                                <path
                                d="M222.37,158.46l-47.11-21.11-.13-.06a16,16,0,0,0-15.17,1.4,8.12,8.12,0,0,0-.75.56L134.87,160c-15.42-7.49-31.34-23.29-38.83-38.51l20.78-24.71c.2-.25.39-.5.57-.77a16,16,0,0,0,1.32-15.06l0-.12L97.54,33.64a16,16,0,0,0-16.62-9.52A56.26,56.26,0,0,0,32,80c0,79.4,64.6,144,144,144a56.26,56.26,0,0,0,55.88-48.92A16,16,0,0,0,222.37,158.46ZM176,208A128.14,128.14,0,0,1,48,80a40.2,40.2,0,0,1,34.87-40,.61.61,0,0,0,0,.12l21,47L83.2,111.86a6.13,6.13,0,0,0-.57.77,16,16,0,0,0-1,15.7c9.06,18.53,27.73,37.06,46.46,46.11a16,16,0,0,0,15.75-1.14,8.44,8.44,0,0,0,.74-.56L168.89,152l47,21.05h0s.08,0,.11,0A40.21,40.21,0,0,1,176,208Z" />
                            </svg>
                            <a href="tel:@Model.Phone" target="_blank">@Model.Phone</a>
                        </div>

                        <div class="contact-item">
                            <svg fill="#fff" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                                <path
                                d="M224,48H32a8,8,0,0,0-8,8V192a16,16,0,0,0,16,16H216a16,16,0,0,0,16-16V56A8,8,0,0,0,224,48Zm-96,85.15L52.57,64H203.43ZM98.71,128,40,181.81V74.19Zm11.84,10.85,12,11.05a8,8,0,0,0,10.82,0l12-11.05,58,53.15H52.57ZM157.29,128,216,74.18V181.82Z" />
                            </svg>
                            <a href="mailto:@Model.Email" target="_blank">@Model.Email</a>
                        </div>

                        @foreach (var link in Model.Links)
                        {
                            <div class="contact-item">
                                <svg fill="#fff" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
                                    <path
                                    d="M128,24h0A104,104,0,1,0,232,128,104.12,104.12,0,0,0,128,24Zm88,104a87.61,87.61,0,0,1-3.33,24H174.16a157.44,157.44,0,0,0,0-48h38.51A87.61,87.61,0,0,1,216,128ZM102,168H154a115.11,115.11,0,0,1-26,45A115.27,115.27,0,0,1,102,168Zm-3.9-16a140.84,140.84,0,0,1,0-48h59.88a140.84,140.84,0,0,1,0,48ZM40,128a87.61,87.61,0,0,1,3.33-24H81.84a157.44,157.44,0,0,0,0,48H43.33A87.61,87.61,0,0,1,40,128ZM154,88H102a115.11,115.11,0,0,1,26-45A115.27,115.27,0,0,1,154,88Zm52.33,0H170.71a135.28,135.28,0,0,0-22.3-45.6A88.29,88.29,0,0,1,206.37,88ZM107.59,42.4A135.28,135.28,0,0,0,85.29,88H49.63A88.29,88.29,0,0,1,107.59,42.4ZM49.63,168H85.29a135.28,135.28,0,0,0,22.3,45.6A88.29,88.29,0,0,1,49.63,168Zm98.78,45.6a135.28,135.28,0,0,0,22.3-45.6h35.66A88.29,88.29,0,0,1,148.41,213.6Z" />
                                </svg>
                                <a href="@link" target="_blank" rel="noopener" class="inline-block text-wrap break-all">
                                    @if (Uri.TryCreate(link, UriKind.Absolute, out var uri))
                                    {
                                        if (uri.Host.StartsWith("www.", StringComparison.OrdinalIgnoreCase))
                                        {
                                            @uri.Host.Substring(4).Split('.')[0].ToLower()
                                        }
                                        else
                                        {
                                            @uri.Host.Split('.')[0].ToLower()
                                        }
                                    }
                                    else
                                    {
                                        @link
                                    }
                                </a>
                            </div>
                        }
                    </div>

                    <div class="sidebar--data">
                        <h2 class="sidebar--title">Skills</h2>
                        <ul class="sidebar--list">
                            @foreach (var skill in Model.Skills)
                            {
                                <li class="sidebar--item skill-item">
                                    <span class="sidebar--label">@skill.Name</span>
                                    @if (skill.Keywords.Any())
                                    {
                                        <div class="skills-keywords">
                                            @string.Join(", ", skill.Keywords)
                                        </div>
                                    }
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="sidebar--data">
                        <h2 class="sidebar--title">Languages</h2>
                        <ul class="sidebar--list">
                            @foreach (var language in Model.Languages)
                            {
                                <li class="language-item">
                                    <div class="language-name">@language.Name
                                        @if (!string.IsNullOrEmpty(language.Fluency))
                                        {
                                            <text>(@language.Fluency)</text>
                                        }
                                    </div>
                                    <div class="language-level-dots">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= language.Level)
                                            {
                                                <div class="level-dot active"></div>
                                            }
                                            else
                                            {
                                                <div class="level-dot"></div>
                                            }
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </aside>

                <div class="sections">
                    <div class="section--name">
                        <h1>@Model.Name</h1>
                        <h2>@Model.Headline</h2>
                    </div>

                    <div class="section section--summary">
                        <div class="section--content">
                            <p>@Raw(Model.Summary)</p>
                        </div>
                    </div>

                    <div class="section">
                        <div class="section--title">
                            <h2>Work experience</h2>
                        </div>
                        <ol class="section--list">
                            @foreach (var experience in Model.Experiences)
                            {
                                <li class="section--item">
                                    <div class="section--heading-group">
                                        <div class="section--date">@experience.Period</div>
                                        <div class="section--heading">
                                            <h3>@experience.Position</h3>
                                        </div>
                                        <div class="section--sub-heading">
                                            @if (experience.Website != null)
                                            {
                                                <a href="@experience.Website.AbsoluteUri" target="_blank" rel="noopener"
                                                   style="color: #333; text-decoration: none;">@experience.Company</a>
                                            }
                                            else
                                            {
                                                @experience.Company
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(experience.Description))
                                        {
                                            <div class="section--content">
                                                @Raw(experience.Description)
                                            </div>
                                        }
                                    </div>
                                </li>
                            }
                        </ol>
                    </div>

                    <div class="section">
                        <div class="section--title">
                            <h2>Education and Qualifications</h2>
                        </div>
                        <ol class="section--list">
                            @foreach (var education in Model.Educations)
                            {
                                <li class="section--item">
                                    <div class="section--heading-group">
                                        <div class="section--date">@education.Period</div>
                                        <div class="section--heading">
                                            <h3>@education.Degree</h3>
                                        </div>
                                        <div class="section--sub-heading">
                                            @if (education.Website != null)
                                            {
                                                <a href="@education.Website.AbsoluteUri" target="_blank" rel="noopener"
                                                   style="color: #333; text-decoration: none;">@education.School</a>
                                            }
                                            else
                                            {
                                                @education.School
                                            }
                                            @if (!string.IsNullOrEmpty(education.Location))
                                            {
                                                <text>, @education.Location</text>
                                            }
                                        </div>
                                        @if (!string.IsNullOrEmpty(education.Area))
                                        {
                                            <div class="section--content">
                                                <p>@education.Area</p>
                                            </div>
                                        }
                                    </div>
                                </li>
                            }
                        </ol>
                    </div>

                    <div class="section">
                        <div class="section--title">
                            <h2>Certification</h2>
                        </div>
                        <div class="section--content section--content-single-textarea">
                            <ul>
                                @foreach (var cert in Model.Certifications)
                                {
                                    <li>
                                        <strong>@cert.Title</strong>
                                        @if (!string.IsNullOrEmpty(cert.Issuer))
                                        {
                                            <text> - @cert.Issuer</text>
                                        }
                                        @if (!string.IsNullOrEmpty(cert.Date))
                                        {
                                            <text> (@cert.Date)</text>
                                        }
                                        @if (cert.Website != null)
                                        {
                                            <text> - <a href="@cert.Website.AbsoluteUri" target="_blank"
                                                            rel="noopener">@cert.Label</a></text>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </body>

    </html>